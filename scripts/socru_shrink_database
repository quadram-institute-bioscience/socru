#!/usr/bin/env python3
"""
Command-line utility to optimize a Socru database by reducing fragment redundancy.

This administrative tool analyzes BLAST results from multiple genome analyses to identify
fragments that are rarely or never found in real genomes. It creates a new, optimized
database containing only the essential fragments, which reduces database size and
improves analysis performance while maintaining typing accuracy.

This is particularly useful for large, comprehensive databases where some theoretical
fragment combinations may not occur in practice.
"""

import sys
import argparse
import os
from importlib.metadata import version as get_version
# Add parent and current directories to path for module imports
sys.path.append('../')
sys.path.append('./')
from socru.SocruShrinkDatabase import SocruShrinkDatabase

# Set up command-line argument parser
parser = argparse.ArgumentParser(
	description = 'Admin utility take a database and blast results and create a new shrunk database',
	usage = 'socru_shrink_database [options]',
    formatter_class=argparse.ArgumentDefaultsHelpFormatter)

# Positional arguments - required inputs	
parser.add_argument('blast_results',  help='Blast results file from running socru -b xxx against multiple assemblies', type=str )
parser.add_argument('input_database',  help='Directory containing database to shrink', type=str )
parser.add_argument('output_database', help="Output directory for new database, it must not already exist", type=str)

# Database optimization options
parser.add_argument('--min_fragment_size', help="Minimum fragment size in bases", type=int, default = 100000)

# Debugging and information options
parser.add_argument('--debug', action='store_true', help='Turn on debugging', default = False)
parser.add_argument('--verbose', '-v', action='store_true', help='Turn on verbose output', default = False)
parser.add_argument('--version', action='version', version='%(prog)s ' + get_version('socru'))

# Parse command-line arguments
options = parser.parse_args()

# Create the optimized database
g = SocruShrinkDatabase(options)
print(g.run())
