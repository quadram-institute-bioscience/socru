#!/usr/bin/env python3
"""
Command-line utility to rebuild and renumber a Socru profile database.

This administrative tool takes an existing profile.txt file and reconstructs it with
standardized numbering and formatting. It reassigns GS (Genome Structure) type numbers
in a systematic way, which is useful when profiles have been manually edited or when
consolidating multiple profile versions.

The tool maintains all the fragment patterns but provides them with clean, sequential
GS type identifiers (e.g., GS1.1, GS1.2, etc.).
"""

import sys
import argparse
import os
from importlib.metadata import version as get_version
# Add parent and current directories to path for module imports
sys.path.append('../')
sys.path.append('./')
from socru.SocruRebuildProfile import SocruRebuildProfile

# Set up command-line argument parser with citation information
parser = argparse.ArgumentParser(
    description = '''
    "Admin utility which will take in an existing profile and rebuild it. Please cite our paper, Socru: Typing of genome level order and orientation in bacteria", 
    Andrew J Page, Gemma Langridge, 
    bioRxiv 543702; (2019) doi: https://doi.org/10.1101/543702''',
    usage = 'socru_rebuild_profile [options]',
    formatter_class=argparse.ArgumentDefaultsHelpFormatter)

# Positional arguments - required inputs
parser.add_argument('profile_filename', help="profile.txt from database", type=str)

# Output options
parser.add_argument('--output_file', '-o',  help='Output filename', type=str, default = 'updated_profile.txt')
parser.add_argument('--prefix', '-p',  help='Prefix', type=str, default = 'GS')

# Debugging and information options
parser.add_argument('--debug', action='store_true', help='Turn on debugging', default = False)
parser.add_argument('--verbose', '-v', action='store_true', help='Turn on verbose output', default = False)
parser.add_argument('--version', action='version', version='%(prog)s ' + get_version('socru'))

# Parse command-line arguments
options = parser.parse_args()

# Rebuild the profile with standardized numbering
with SocruRebuildProfile(options) as g:
    g.run()
